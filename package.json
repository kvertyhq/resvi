{
  "name": "kverty-bistro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mobile:pos": "node scripts/mobile-env.js pos && cross-env VITE_APP_MODE=pos tsc -b && vite build && npx cap sync",
    "build:mobile:admin": "node scripts/mobile-env.js admin && cross-env VITE_APP_MODE=admin tsc -b && vite build && npx cap sync",
    "build:mobile:default": "tsc -b && vite build && npx cap sync",
    "save:mobile:admin": "shx rm -rf ios-admin android-admin && shx cp -R ios ios-admin && shx cp -R android android-admin",
    "save:mobile:pos": "shx rm -rf ios-pos android-pos && shx cp -R ios ios-pos && shx cp -R android android-pos",
    "preview": "vite preview",
    "tauri:dev": "npm run sync-version && npx @tauri-apps/cli dev",
    "tauri:build": "npm run sync-version && npx @tauri-apps/cli build",
    "sync-version": "node scripts/sync-version.js"
  },
  "dependencies": {
    "@bcyesil/capacitor-plugin-printer": "0.0.6",
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.9",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.5.3",
    "@supabase/supabase-js": "^2.78.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.554.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.11.3",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.5",
    "sip.js": "^0.21.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.8",
    "shx": "^0.4.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
