{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Resvi POS",
  "version": "0.1.0",
  "identifier": "com.kverty.resvi",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Resvi POS",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:3000; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://qbgziszculmwzyhjvfyc.supabase.co; connect-src 'self' https://qbgziszculmwzyhjvfyc.supabase.co wss://qbgziszculmwzyhjvfyc.supabase.co http://localhost:3000;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}