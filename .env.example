# Gemini API Key for AI features
GEMINI_API_KEY=your_gemini_api_key_here

# --- Tauri Signing Configuration ---

# 1. Windows Authenticode Signing (for the .exe/.msi)
# Path to your .pfx or .p12 certificate file (relative to root or absolute)
SIG_CERTIFICATE=codesigning.pfx
# Password for the certificate file
SIG_PASSWORD=your_certificate_password_here

# 2. Tauri Updater Signing (for the updater signature)
# The content of your private key file (src-tauri/signer.key)
TAURI_SIGNING_PRIVATE_KEY="untrusted comment: minisign private key: ..."
# Password for the private key (if you set one during generation)
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=your_updater_key_password_here
