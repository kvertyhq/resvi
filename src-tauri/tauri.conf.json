{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Resvi POS",
  "version": "1.0.1",
  "identifier": "com.kverty.resvi",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Resvi POS",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https:; style-src 'self' 'unsafe-inline' blob: https:; img-src 'self' data: https:; connect-src 'self' https: wss:; media-src 'self' https:; font-src 'self' https:;"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3RTEzMDE1OUU5MjM5RkMKUldUOE9aS2VGVERoUjhXYjYwa3JDaTRNbXp0RHpPbnZ2Mzk0Y1FSR3YxRERPVnlEL0pDNU85NEsK",
      "endpoints": [
        "https://raw.githubusercontent.com/kvertyhq/resvi-packages/main/latest.json"
      ]
    },
    "process": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "signCommand": "C:\\nvm4w\\nodejs\\node.exe K:\\Development\\Kverty\\resvi\\scripts\\sign.js %1"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}